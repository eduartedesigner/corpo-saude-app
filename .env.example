# =============================================
# App Corpo e Saúde — Environment Variables
# =============================================

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Claude AI (for workout generation)
EXPO_PUBLIC_AI_API_URL=https://your-api.com/ai
# Note: Claude API key should NEVER be in the client.
# Use a backend proxy (Supabase Edge Function) to call Claude.

# Payment (Asaas)
EXPO_PUBLIC_ASAAS_ENV=sandbox
